# ─── Environment variables ───────────────────────────────────────────────────
# Copy to .env.local for local dev, and set the same keys in your Vercel project
# (Settings → Environment Variables). Every value here is YOURS — never reuse
# another instance's keys. Anything marked (optional) can be left unset.

# ── Supabase (required) — from your own Supabase project → Settings → API ──────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # SECRET — server only, never expose

# ── App URL (required) — your deployed portal domain, no trailing slash ────────
NEXT_PUBLIC_APP_URL=https://portal.yourbusiness.com.au

# ── Email (required for sending) — Resend, with YOUR verified sending domain ───
RESEND_API_KEY=your-resend-api-key

# ── Web push notifications (required for push) — generate a fresh VAPID pair ────
# npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key          # SECRET
VAPID_SUBJECT=mailto:you@yourbusiness.com.au

# ── Scheduled jobs (required for follow-up crons) — any long random string ─────
CRON_SECRET=a-long-random-string

# ── PDF rendering (optional) — PDFShift, for emailed PDF attachments ───────────
PDFSHIFT_API_KEY=your-pdfshift-key

# ── AI features (optional) — Anthropic, if you use the AI helpers ──────────────
ANTHROPIC_API_KEY=your-anthropic-key

# ── Xero accounting integration (optional) — only if you connect Xero ──────────
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=
